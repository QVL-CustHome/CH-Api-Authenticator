# Secrets de CH-Api-Authenticator — copier vers .env (jamais commité).

# Secret de signature des JWT (HS256). OBLIGATOIRE, minimum 32 octets.
# Partagé avec aucun autre service : seule cette API signe et valide.
JWT_SECRET=changez-moi-par-un-secret-d-au-moins-32-octets

# Connexion MongoDB. OBLIGATOIRE.
MONGO_URI=mongodb://localhost:27017/custhome_auth

# Seed du premier super-admin au démarrage (US-01) — créé seulement s'il n'existe pas.
ADMIN_EMAIL=admin@custhome.local
ADMIN_PASSWORD=changez-moi
