# Secrets de CH-Api-Authenticator — copier vers .env (jamais commité).

# Secret de signature des JWT (HS256). OBLIGATOIRE, minimum 32 octets.
# Partagé avec aucun autre service : seule cette API signe et valide.
JWT_SECRET=changez-moi-par-un-secret-d-au-moins-32-octets

# Secret d'authentification inter-services pour /internal/users/resolve.
# OBLIGATOIRE, minimum 32 octets, DISTINCT de JWT_SECRET.
# Envoye par les services appelants (ex. CH-Api-Drive) dans le header x-internal-secret.
# Doit avoir la meme valeur cote Authenticator et cote appelants.
INTERNAL_API_SECRET=changez-moi-par-un-secret-interne-d-au-moins-32-octets

# Connexion MongoDB. OBLIGATOIRE.
MONGO_URI=mongodb://localhost:27017/custhome_auth

# Seed du premier super-admin au démarrage (US-01) — créé seulement s'il n'existe pas.
ADMIN_EMAIL=admin@custhome.local
ADMIN_PASSWORD=changez-moi

# Port d'écoute (surcharge config.toml server.port)
PORT=8181

# Service Missive (envoi des emails de reset). MISSIVE_API_SECRET OBLIGATOIRE :
# envoye dans le header x-internal-secret de POST {MISSIVE_URL}/v1/send.
# MISSIVE_URL surcharge la valeur config.toml [missive].url (defaut http://localhost:8184).
MISSIVE_URL=http://localhost:8184
MISSIVE_API_SECRET=changez-moi-par-le-secret-partage-avec-missive

# Publication des events sur le bus Relay (US SCRUM-254) — requis uniquement si
# relay.enabled = true dans config.toml. Clé privée RSA (PEM PKCS#1 ou PKCS#8)
# servant à signer le JWT RS256 présenté à Relay comme mot de passe MQTT.
# RELAY_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Audiences (aud) des JWT par portail — surchargent les valeurs par défaut du code.
# Doivent rester alignées avec l'audience attendue par chaque service appelant
# (sinon les tokens sont rejetés côté service). Valeurs de contrat publiques.
# JWT_AUDIENCE_DRIVE=ch-api-drive
JWT_AUDIENCE_BUDGY=ch-api-budgy

# Surcharges config.toml via préfixe CH__ (Figment).
# Toute clé de config.toml est surchargeable : CH__SECTION__CLE
# Exemples :
# CH__PASSWORD_RESET__URL=http://localhost:3200/reset-password
# CH__SERVER__LOG_LEVEL=DEBUG
